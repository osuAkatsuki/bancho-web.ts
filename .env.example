# --- build-time configuration (VITE_* vars are baked into the bundle) ---

# display name of your server, shown in the navbar & page titles
VITE_APP_NAME=bancho.py

# your server's domain, used for "how to connect" instructions
VITE_BANCHO_DOMAIN=cmyui.xyz

# base url of bancho.py's api (api.{DOMAIN}).
# "/api" works with the dev proxy (see below) or an nginx location that
# proxies {frontend-domain}/api/* to bancho.py with `Host: api.{DOMAIN}`.
VITE_API_BASE_URL=/api

# base url for avatars (a.{DOMAIN})
VITE_AVATARS_BASE_URL=https://a.cmyui.xyz

# --- dev-server-only configuration (used by vite.config.ts proxy) ---

# where your local bancho.py instance is listening
BANCHO_API_TARGET=http://127.0.0.1:10000

# domain used to build the proxied Host header (api.{BANCHO_DOMAIN})
BANCHO_DOMAIN=cmyui.xyz
